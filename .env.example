# Public Supabase project URL.
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key used by browser and server-side auth helpers.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional local-only key for scripts/import-markdown-source-package.ts apply mode.
# Never expose this key to browser code, app routes, components, or server actions.
SUPABASE_SERVICE_ROLE_KEY=
